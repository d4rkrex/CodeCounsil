{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeCounsil Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domains",
    "category",
    "classification",
    "severity",
    "priority",
    "confidence",
    "status",
    "observation",
    "impact",
    "recommendation"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^CC-[A-Z]+-\\d{3}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "architecture",
          "developer",
          "qa",
          "security",
          "ux",
          "sre",
          "finops",
          "product",
          "data_privacy",
          "ai",
          "api_design",
          "ai_security",
          "ai_quality"
        ]
      }
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "classification": {
      "type": "string",
      "enum": [
        "confirmed_finding",
        "probable_risk",
        "design_weakness",
        "documentation_gap",
        "test_gap",
        "improvement",
        "insufficient_evidence"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "info"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3",
        "P4"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "confirmed",
        "rejected",
        "downgraded",
        "upgraded",
        "merged",
        "unverifiable",
        "pending"
      ]
    },
    "observation": {
      "type": "string",
      "minLength": 1
    },
    "impact": {
      "type": "string",
      "minLength": 1
    },
    "recommendation": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "file",
          "start_line",
          "end_line",
          "description"
        ],
        "properties": {
          "file": {
            "type": "string",
            "minLength": 1
          },
          "start_line": {
            "type": "integer",
            "minimum": 1
          },
          "end_line": {
            "type": "integer",
            "minimum": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effort": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "challenger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "reasoning"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "confirmed",
            "rejected",
            "downgraded",
            "upgraded",
            "merged",
            "unverifiable",
            "pending"
          ]
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
